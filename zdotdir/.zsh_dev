# 
# pnpm
# 
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

#
# cargo
#
. "$HOME/.cargo/env"

#
# mise
#
eval "$(/opt/homebrew/bin/mise activate zsh)"

#
# Claude
#
export PATH="$HOME/.local/bin:$PATH"

